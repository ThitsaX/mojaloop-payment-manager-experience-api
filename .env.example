INBOUND_LISTEN_PORT=3000

# Use mock data
MOCK_DATA=false

# The number of space characters by which to indent pretty-printed logs. If set to zero, log events
# will each be printed on a single line.
LOG_INDENT=0

MANAGEMENT_ENDPOINT=localhost:9000
DFSP_ID=pm4mltest

# Cache configuration for high-volume scenarios
CACHE_SYNC_INTERVAL_SECONDS=30
CACHE_SYNC_BATCH_SIZE=100
CACHE_MAX_INITIAL_SYNC_KEYS=1000

# MySQL Database Configuration
# Required for persistent storage of transfer data
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=pm4ml
DATABASE_PASSWORD=your-secure-password-here
DATABASE_NAME=pm4ml_experience_api

# Database connection timeouts (milliseconds)
DATABASE_CONNECTION_TIMEOUT=10000
DATABASE_ACQUIRE_TIMEOUT=10000

# Database connection pool settings
# Adjust based on expected concurrent load
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_POOL_ACQUIRE_TIMEOUT=30000
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_POOL_CREATE_TIMEOUT=30000

ENABLE_AUTH_CLIENT=false
